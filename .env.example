JARVIS_ENVIRONMENT=development
JARVIS_SERVICE_NAME=jarvis-api
JARVIS_MODEL_MODE=deterministic
JARVIS_DATABASE_URL=postgresql://jarvis:jarvis@localhost:5432/jarvis
JARVIS_DATABASE_SCHEMA=public
JARVIS_DATABASE_CONNECT_TIMEOUT_SECONDS=2
JARVIS_API_TOKEN=replace-for-shared-development
JARVIS_OPENAI_API_KEY=
JARVIS_DEEPSEEK_API_KEY=
JARVIS_OPENAI_FAST_MODEL=gpt-5.6-luna
JARVIS_OPENAI_REASONING_MODEL=gpt-5.6-terra
JARVIS_DEEPSEEK_FAST_MODEL=deepseek-v4-flash
JARVIS_DEEPSEEK_REASONING_MODEL=deepseek-v4-pro

# Optional. Required only by `make smoke-models`; never commit real values.
OPENAI_API_KEY=
DEEPSEEK_API_KEY=
JARVIS_OPENAI_MODEL=gpt-5.6-luna
JARVIS_DEEPSEEK_MODEL=deepseek-v4-flash
# Restrict LangGraph checkpoint deserialization to safe built-in data.
LANGGRAPH_STRICT_MSGPACK=true

POSTGRES_DB=jarvis
POSTGRES_USER=jarvis
POSTGRES_PASSWORD=jarvis
POSTGRES_PORT=5432
